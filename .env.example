OPENAI_API_KEY=sk-your-key-here
# Required for multi-provider routing (Claude, Gemini, GPT in one run).
# OpenRouter (recommended): https://openrouter.ai/api/v1
# LiteLLM proxy: http://your-litellm-host/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional config overrides (precedence: CLI > env > ~/.verd.yaml > defaults)
# VERD_JUDGE=gpt-5.4
# VERD_DEBATERS=claude-sonnet-4-6,gpt-4.1,gemini-2.5-flash
# VERD_BUDGET=1.00
# VERD_TIMEOUT=30
#
# NOTE: Model names must match your provider's IDs. OpenRouter uses names like
# "claude-sonnet-4-6" and "gemini-2.5-flash" — LiteLLM proxies may use
# "anthropic/claude-sonnet-4-6", "google/gemini-2.5-flash", etc.
# Override via ~/.verd.yaml if your provider uses different names.

# Slack bot (optional — only needed for verd-slack)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
